{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2021",
    "jsx": "react-jsx",
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "lib": ["dom", "esnext"],
    "paths": {
      "@/*": ["./frontend/src/*"],
      "images/*": ["./frontend/src/images/*"],
    }
  },
  "include": ["frontend/**/*"]
}

